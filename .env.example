# ── JerezBudget API — Variables de entorno ──────────────────────────────────
# Copiar a .env y rellenar valores reales. NUNCA commitar .env a git.

# Base de datos PostgreSQL
DB_NAME=jerezbudget
DB_USER=jerezbudget
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO

# URL completa (generada en docker-compose, pero útil para dev local)
DATABASE_URL=postgresql+asyncpg://jerezbudget:CAMBIAR_PASSWORD_SEGURO@localhost:5432/jerezbudget

# Redis
REDIS_PASSWORD=CAMBIAR_REDIS_PASSWORD
REDIS_URL=redis://:CAMBIAR_REDIS_PASSWORD@localhost:6379/0

# MinIO (almacenamiento de ficheros fuente XLSX/PDF)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CAMBIAR_MINIO_PASSWORD
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=jerezbudget-sources
MINIO_SECURE=false

# API
API_DEBUG=true
API_SECRET_KEY=CAMBIAR_SECRET_KEY_64_CHARS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Scraping
TRANSPARENCIA_BASE_URL=https://transparencia.jerez.es
SCRAPE_INTERVAL_HOURS=24
# User-agent respetuoso con el servidor
HTTP_USER_AGENT=JerezBudgetBot/1.0 (civic-tech; intramurosjerez.org)

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json    # json | console
